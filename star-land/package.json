{
  "name": "star-land",
  "private": true,
  "version": "1.0.0",
  "description": "老田和小甜甜的游戏屋 - 融合全球十大教学法的亲子共学补救学习系统",
  "author": "天轰穿 <QQ:110535808>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "electron:dev": "vite build --base=./ && electron .",
    "electron:build": "vite build --base=./ && electron-builder --win portable",
    "electron:build:installer": "vite build --base=./ && electron-builder --win nsis",
    "electron:build:all": "vite build --base=./ && electron-builder --win nsis portable",
    "android:build": "vite build --base=./ && npx cap sync android && npx cap open android"
  },
  "build": {
    "appId": "com.oldsweetie.newgamehouse",
    "productName": "老甜甜和小甜甜的游戏屋",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "electron/**/*",
      "!**/node_modules/**",
      "!**/.git/**",
      "!**/.vscode/**"
    ],
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "afterPack": "electron/afterPack.cjs",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "老甜甜和小甜甜的游戏屋",
      "artifactName": "老甜甜和小甜甜的游戏屋-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "老甜甜和小甜甜的游戏屋-${version}-portable.exe"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "gsap": "^3.12.5",
    "lucide-vue-next": "^0.511.0",
    "pinia": "^2.1.7",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.0.12",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vue-tsc": "^1.8.27"
  }
}
